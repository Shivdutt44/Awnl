        "question_ytTTXX": {
          "type": "question",
          "settings": {
            "category_index": 3,
            "question": "可以使用折扣碼嗎?",
            "answer": "<p>可以。客製化手鍊支援使用新客折扣碼、會員積分折扣等優惠，在結帳時於「禮品卡或折扣碼」欄位輸入並套用即可。</p><p>*特殊活動折扣或部分不適用</p>",
            "link": "",
