      "blocks": {
        "richtext_E4nMi9": {
          "type": "richtext",
          "settings": {
            "content": "<p>占星術不僅包括星座，數字占卜學（占數術）也是一個重要的領域。占數術中的「生命靈數（Life Path Number）」代表著一個人的本質性格和人生傾向。生命靈數揭示了您的才華和內在特質，並與相應的寶石能量和顏色搭配使用，有助於提升您的氣場和運勢。</p>"
          }
        }
      },
      "block_order": [
