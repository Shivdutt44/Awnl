<form action="/cart/add.js" method="POST">
  <div class="product-summery">
    <p class="size">Size: <b></b></p>
    <p class="string-color">Color: <b></b></p>
    <p class="lock-style">Lock Style: <b></b></p>
    <p class="gender">Gender: <b></b></p>
    <p class="price">Base Price: <b><span>{{ product.price | money_with_currency }}</span></b></p>
  </div>

  <!-- Hidden input for the selected product's variant ID -->
  <input type="hidden" name="id" value="{{ product.variants.first.id }}">
  <input id="custom_photo" type="hidden" name="properties[Image]" style="display:none;" aria-label="input 85">
  <!-- Quantity Input -->
  <input type="hidden" name="quantity" value="1" class="quantity">

  <!-- Line Item Properties (custom data) -->
  <input type="hidden" name="properties[Bracelet Size]" value="">
  <input type="hidden" name="properties[String Color]" value="">
  <input type="hidden" name="properties[Lock Style]" value="">
  <input type="hidden" name="properties[Gender]" value="">
  <!-- <input type="hidden" name="properties[Base Price]" value="${{ product.price | divided_by: 100 }}"> -->

  <!-- Product Bundle Section -->
  <div class="stone-costing">
    <!-- Optional: Add dynamic stones with JavaScript as properties -->
  </div>

