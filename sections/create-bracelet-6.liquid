<style>
  /* Full-screen overlay */
  #loadingOverlay {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.6);
    z-index: 9999;
    justify-content: center;
    align-items: center;
  }

  /* Center text and loader */
  .loadingContent {
    text-align: center;
    color: white;
    font-size: 20px;
    font-family: Arial, sans-serif;
  }

  /* Loader container */
  .loader {
    position: relative;
    width: 120px;
    height: 120px;
    margin: 0 auto 15px;
  }

  /* Static logo */
  .loader .logo {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 100px;
    z-index: 2;
  }

  /* Rotating ring */
  .loader .ring {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 100px;
    height: 100px;
    border: 5px solid transparent;
    border-top: 5px solid #ffffff;
    border-radius: 50%;
    transform: translate(-50%, -50%);
    animation: spin 1.5s linear infinite;
  }

  /* Rotation animation */
  @keyframes spin {
    from { transform: translate(-50%, -50%) rotate(0deg); }
    to { transform: translate(-50%, -50%) rotate(360deg); }
  }

  /* Animated dots for text */
  .dots::after {
    content: '';
    animation: dots 1.5s infinite steps(3, end);
  }

  @keyframes dots {
    0% { content: ''; }
    33% { content: '.'; }
    66% { content: '..'; }
    100% { content: '...'; }
  }


