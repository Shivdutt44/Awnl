    <span class="price-count">{{ product.price | money_with_currency }}</span>
  </div>

    <div class="product-summery">
    <p class="size">Gift Wrapping: 
     <span class="radio-form">
         <label>Free
         <input type="radio" name="properties[Gift Wrapping]" value="free" checked>
         </label>
         {% comment %} <label>Option 1
         <input type="radio" name="properties[Gift Wrapping]" value="$12">
         </label>
         <label>Option 2
         <input type="radio" name="properties[Gift Wrapping]" value="$15">
         </label> {% endcomment %}
     </span>
    </p>
    
      {% if product.metafields.custom.engraving != blank %}
  {% assign engraving_files = product.metafields.custom.engraving.value %}

  {% if engraving_files != blank %}
    <div class="engraving-options">
      {% for file in engraving_files %}
        {% assign file_name = file.src | split: '/' | last %}
        <label class="engraving-card">
          <input 
            type="radio" 
            name="properties[Engraving]" 
            value="{{ file_name | split:"." | first }}" 
            {% if forloop.first %}checked{% endif %}
          >
          <div class="engraving-preview">
            <img src="{{ file.src | img_url: '200x200' }}" alt="{{ file_name | split:"." | first }}">
          </div>
          {% comment %} <span class="engraving-name">{{ file_name }}</span> {% endcomment %}
        </label>
      {% endfor %}
    </div>
  {% endif %}
{% endif %}


    <p class="size">Text: 
     <span class="radio-form">
         <input type="text" name="properties[Text]" placeholder="輸入刻印文字" id="engraving-text">
          <small id="engraving-instruction" style="display:block; color:#555;">
            選擇字體，輸入專屬文字，專屬印記將鐫刻於您所選的刻印配件上。
