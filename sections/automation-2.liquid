  'l': {{ section.settings.bead_count_l | default: 16 }},
  'xl': {{ section.settings.bead_count_xl | default: 17 }},
  'xxl': {{ section.settings.bead_count_xxl | default: 18 }},
  'xxxl': {{ section.settings.bead_count_xxxl | default: 19 }},
  '4xl': {{ section.settings.bead_count_4xl | default: 20 }}
};

let fixedParts = [
  {% if section.settings.fixed_part_1_enabled %}{ angle: {{ section.settings.fixed_part_1_angle | default: 0 }}, width: {{ section.settings.fixed_part_1_width | default: 30 }}, enabled: true },{% endif %}
  {% if section.settings.fixed_part_2_enabled %}{ angle: {{ section.settings.fixed_part_2_angle | default: 120 }}, width: {{ section.settings.fixed_part_2_width | default: 30 }}, enabled: true },{% endif %}
  {% if section.settings.fixed_part_3_enabled %}{ angle: {{ section.settings.fixed_part_3_angle | default: 240 }}, width: {{ section.settings.fixed_part_3_width | default: 30 }}, enabled: true },{% endif %}
];

if (window.location.href.includes('style-3') || {{ product.handle | json }}.includes('style-3') || window.location.href.includes('style3')) {
  fixedParts = [{ angle: 270, width: 60, enabled: true }];
}

const beadSettings = {
  size: {{ section.settings.bead_size | default: 45 }},
  radius: {{ section.settings.bead_radius | default: 41 }},
  centerX: {{ section.settings.center_x | default: 50 }},
  centerY: {{ section.settings.center_y | default: 50 }}
};

const equalSpacing = {{ section.settings.equal_spacing | default: 0 }};

const sizeGaps = {
  'xxs': {{ section.settings.gap_xxs | default: 0 }},
  'xs': {{ section.settings.gap_xs | default: 0 }},
  's': {{ section.settings.gap_s | default: 0 }},
  'm': {{ section.settings.gap_m | default: 0 }},
  'l': {{ section.settings.gap_l | default: 0 }},
  'xl': {{ section.settings.gap_xl | default: 0 }},
  'xxl': {{ section.settings.gap_xxl | default: 0 }},
  'xxxl': {{ section.settings.gap_xxxl | default: 0 }},
  '4xl': {{ section.settings.gap_4xl | default: 0 }}
};

const quadrantGaps = {
  'top': {{ section.settings.gap_top | default: 0 }},
  'right': {{ section.settings.gap_right | default: 0 }},
  'bottom': {{ section.settings.gap_bottom | default: 0 }},
  'left': {{ section.settings.gap_left | default: 0 }}
};

let selectedStones = {};
let selectedClasp = null; // { variantId, title, price, image, inventory }

// ============================================
// STATIC IMAGES CONFIGURATION
// ============================================
const staticImages = [
  {% if section.settings.static_image_1_enabled and section.settings.static_image_1 %}
