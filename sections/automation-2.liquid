function updateClaspStockUI(card, remaining) {
  const stockLabel = card.querySelector(".bead-stock");
  if (!stockLabel) return;
  if (remaining > 0) {
    stockLabel.textContent = `In stock: ${remaining}`;
    card.classList.remove("is-disabled");
    card.removeAttribute("aria-disabled");
  } else {
    stockLabel.textContent = "Insufficient stock";
    card.classList.add("is-disabled");
    card.setAttribute("aria-disabled", "true");
  }
}

function placeClaspImage() {
  const container = document.getElementById('clasp-image-container');
  if (!container) return;
  container.innerHTML = '';
  if (!selectedClasp) return;
  const parker = document.getElementById('parker');
  const rect = parker.getBoundingClientRect();
  if (!rect.width) return;
  {% if product.handle contains 'style-3' or template.suffix == 'style-3' %}
  // Style-3: place clasp image at both cord tip positions (matching placeKnotBeads positions)
  const parkerSize = Math.min(rect.width, rect.height);
  const centerX = rect.width / 2;
  const centerY = rect.height / 2;
  const radiusPx  = (beadSettings.radius / 100) * parkerSize;
  const cordDist  = radiusPx + (20 / 100) * parkerSize;
  const halfImg   = 50;
  const claspSize = beadSettings.size;
  [250, 290].forEach(angle => {
    const angleRad    = angle * Math.PI / 180;
    const totalRotRad = (angle + 90) * Math.PI / 180;
    const cordCX = centerX + cordDist * Math.cos(angleRad);
    let cordCY = centerY + cordDist * Math.sin(angleRad);

    // Apply vertical shift for all sizes to hide white gaps
    cordCY += (parkerSize * 0.045);
    

    const tipX = cordCX + halfImg * Math.sin(totalRotRad);
    const tipY = cordCY - halfImg * Math.cos(totalRotRad) + parkerSize * 0.05;
    const imgWrapper = document.createElement('div');
    imgWrapper.style.cssText = `
      position: absolute;
      left: ${tipX}px;
      top: ${tipY}px;
      transform: translate(-50%, -50%);
      width: ${claspSize}px;
      height: ${claspSize}px;
      border-radius: 50%;
      overflow: hidden;
      z-index: 10;
      pointer-events: none;
    `;
    const img = document.createElement('img');
    img.src = selectedClasp.image;
    img.alt = selectedClasp.title;
    img.style.cssText = 'width:100%; height:100%; object-fit:cover; display:block;';
    imgWrapper.appendChild(img);
    container.appendChild(imgWrapper);
  });
  {% else %}
  // Other styles: original single-clasp behavior
  const centerX = rect.width / 2;
  const centerY = rect.height / 2;
  const radiusPx = (beadSettings.radius / 100) * Math.min(rect.width, rect.height);
  
  // Calculate a scale factor based on 380px (Size M) so clasp and gaps scale harmoniously
  const scaleFactor = rect.width / 380;
  const baseOffset = {{ section.settings.clasp_offset | default: 150 }};
  const offsetPx = baseOffset * scaleFactor;
  
  const angleDeg = {{ section.settings.clasp_angle | default: 90 }};
  const angleRad = angleDeg * Math.PI / 180;
  const distance = radiusPx + offsetPx;
  const x = centerX + distance * Math.cos(angleRad);
  const y = centerY + distance * Math.sin(angleRad);
  const imgWrapper = document.createElement('div');
  imgWrapper.className = 'static-bead-image';
  imgWrapper.style.cssText = `
    position: absolute;
    left: ${x}px;
    top: ${y}px;
    transform: translate(-50%, -50%) rotate(${angleDeg + 90}deg);
    width: ${ {{ section.settings.clasp_width | default: 60 }} * scaleFactor }px;
    height: ${ {{ section.settings.clasp_height | default: 60 }} * scaleFactor }px;
    z-index: 10;
    pointer-events: none;
  `;
  const img = document.createElement('img');
  img.src = selectedClasp.image;
  img.alt = selectedClasp.title;
  imgWrapper.appendChild(img);
  container.appendChild(imgWrapper);
  {% endif %}
}

