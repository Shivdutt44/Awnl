// MODIFIED placeStaticImages FUNCTION
// ============================================
function placeStaticImages() {
  const parker = document.getElementById('parker');
  if (!parker) return;
  document.querySelectorAll('#static-images-container, #static-image-left, #static-image-right').forEach(container => {
    if (container) container.innerHTML = '';
  });
  const centerX = beadSettings.centerX;
  const centerY = beadSettings.centerY;
  const baseRadius = beadSettings.radius;
  const beadAngles = getBeadAngles();
  staticImages.forEach((image, index) => {
    if (!image.enabled) return;
    let angleDegrees;
    let positionFound = false;
    if (image.type === 'position-based') {
      const beadPositions = getBeadPositions();
      const beadIndex = image.position - 1;
      const bead1 = beadPositions.find(b => b.index === beadIndex);
      let bead2;
      if (beadIndex === beadPositions.length - 1) {
        bead2 = beadPositions[0];
      } else {
        bead2 = beadPositions.find(b => b.index === beadIndex + 1);
      }
      if (bead1 && bead2) {
        const angleRad = calculateAngleBetweenBeads(bead1, bead2, centerX, centerY);
        angleDegrees = angleRad * 180 / Math.PI;
        positionFound = true;
      }
    } else if (image.type === 'dynamic-top') {
      angleDegrees = findClosestGapAngle(beadAngles, 90);
      positionFound = true;
    } else if (image.type === 'dynamic-bottom') {
      angleDegrees = findClosestGapAngle(beadAngles, 270);
      positionFound = true;
    } else if (image.containerId) {
      angleDegrees = image.angle;
      positionFound = true;
    }
    if (!positionFound) return;
    const angleRad = angleDegrees * Math.PI / 180;
    const distance = baseRadius + (image.offset || 0);
    const x = centerX + distance * Math.cos(angleRad);
    let y = centerY + distance * Math.sin(angleRad);

    // Apply vertical shift for all sizes to move strings lower and hide white gaps
    if (image.containerId === 'static-image-left' || image.containerId === 'static-image-right') {
        y += 4.5; // Shift down by 4.5% of container height for all sizes to hide white gaps
    }

    let totalRotation = angleDegrees + 90 + (image.rotation || 0);
    totalRotation = ((totalRotation % 360) + 360) % 360;
    const imgWrapper = document.createElement('div');
    imgWrapper.className = 'static-bead-image';
    const img = document.createElement('img');
    img.src = image.src;
    img.alt = `Static Image ${index + 1}`;
    if (image.flip) img.style.transform = 'scaleX(-1)';
    imgWrapper.appendChild(img);
    imgWrapper.style.cssText = `
      position: absolute;
      left: ${x}%;
      top: ${y}%;
      transform: translate(-50%, -50%) rotate(${totalRotation}deg);
      width: ${image.width}px;
      height: ${image.height}px;
      z-index: 8;
      pointer-events: none;
    `;
    img.style.cssText = `width:100%; height:100%; object-fit:contain; display:block;${image.flip ? ' transform: scaleX(-1);' : ''}`;
    const container = image.containerId ? document.getElementById(image.containerId) : document.getElementById('static-images-container');
    if (container) container.appendChild(imgWrapper);
  });
}

// ============================================
// KNOT BEADS AT CORD TIPS (STYLE-3)
// ============================================
function placeKnotBeads() {
  {% if product.handle contains 'style-3' or template.suffix == 'style-3' %}
  const parker = document.getElementById('parker');
  if (!parker) return;
  ['knot-bead-left', 'knot-bead-right'].forEach(id => {
    const el = document.getElementById(id);
    if (el) el.remove();
  });
  // Get current parker pixel size — used only to convert the fixed 150px cord height to %
  const rect = parker.getBoundingClientRect();
  if (!rect.width) return;
  const parkerSize = Math.min(rect.width, rect.height);
  // Cord center: % coordinates (same formula as placeStaticImages, immune to transition timing)
  const cX = beadSettings.centerX;             // % from left
  const cY = beadSettings.centerY;             // % from top
  const cordDist_pct = beadSettings.radius + 20; // % (radius% + offset 20%, matches staticImages)
  // Cord image is 150px tall; the knot (dark ball) sits ~50px from the image centre
  // (not at the very edge) — using 50px lands the dropper on the knot itself.
  const halfImg_pct = (50 / parkerSize) * 100;
  const knotBeadPlaceholder = `{% if product.metafields.bracelets.beads_placeholder_image.value %}url('{{ product.metafields.bracelets.beads_placeholder_image.value | image_url }}'){% else %}none{% endif %}`;
  const beads = [
    { id: 'knot-bead-left',  angle: 250 },
    { id: 'knot-bead-right', angle: 290 }
  ];
  beads.forEach(bead => {
    const angleRad = bead.angle * Math.PI / 180;
    // Cord image centre in % — identical to placeStaticImages calculation
    const cordCX_pct = cX + cordDist_pct * Math.cos(angleRad);
    let cordCY_pct = cY + cordDist_pct * Math.sin(angleRad);

    // Apply vertical shift for all sizes to move strings lower and hide white gaps
    cordCY_pct += 4.5; 
    

    // Outer tip of cord (the knot) = cord centre + halfImg in the radial direction
    const tipX_pct = cordCX_pct + halfImg_pct * Math.cos(angleRad);
    const tipY_pct = cordCY_pct + halfImg_pct * Math.sin(angleRad);
    const beadPx = beadSettings.size;
    const dot = document.createElement('div');
    dot.id = bead.id;
    dot.className = 'knot-bead-dropper';
    dot.dataset.placeholder = knotBeadPlaceholder;
    dot.style.cssText = `
      position: absolute;
      left: ${tipX_pct.toFixed(2)}%;
      top: ${tipY_pct.toFixed(2)}%;
      transform: translate(-50%, -50%);
      width: ${beadPx}px;
      height: ${beadPx}px;
      background-image: ${knotBeadPlaceholder};
      background-size: contain;
      background-repeat: no-repeat;
      background-position: center;
      border-radius: 50%;
      opacity: 0.3;
      z-index: 9;
      cursor: pointer;
      overflow: hidden;
    `;
    // Click to toggle selection (same as regular droppers)
    dot.addEventListener('click', () => {
      dot.classList.toggle('selected');
      if (dot.classList.contains('selected')) {
        dot.style.outline = '2.5px solid #ffd700';
        dot.style.outlineOffset = '3px';
        dot.style.boxShadow = '0 0 0 3px rgba(255,215,0,0.5), 0 0 12px 4px rgba(255,215,0,0.45)';
      } else {
        dot.style.outline = '';
        dot.style.outlineOffset = '';
        dot.style.boxShadow = '0 2px 6px rgba(0,0,0,0.5)';
      }
    });
    parker.appendChild(dot);
  });
  {% endif %}
}

