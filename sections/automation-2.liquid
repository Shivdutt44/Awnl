      src: "{{ section.settings.static_image_left | image_url: width: 400 }}",
      angle: {% if product.handle contains 'style-3' or template.suffix == 'style-3' %}250{% else %}{{ section.settings.static_image_left_angle | default: 135 }}{% endif %},
