// ============================================
// HELPER FUNCTIONS (BEAD POSITIONING, ETC.)
// ============================================
function redistributeGaps(originalAngles, targetIndices, extraSpacings) {
  const n = originalAngles.length;
  if (n === 0) return originalAngles;
  let gaps = [];
  for (let i = 0; i < n; i++) {
    const next = (i + 1) % n;
    let gap = originalAngles[next] - originalAngles[i];
    if (gap < 0) gap += 360;
    gaps.push(gap);
  }
  let totalExtra = 0;
  for (let idx = 0; idx < targetIndices.length; idx++) {
    const i = targetIndices[idx];
    const extra = extraSpacings[idx];
    gaps[i] += extra;
    totalExtra += extra;
  }
  const currentSum = gaps.reduce((a, b) => a + b, 0);
  const adjust = (360 - currentSum) / (n - targetIndices.length);
  const nonTargetIndices = [];
  for (let i = 0; i < n; i++) {
    if (!targetIndices.includes(i)) nonTargetIndices.push(i);
  }
  if (nonTargetIndices.length > 0) {
    for (const i of nonTargetIndices) {
      gaps[i] += adjust;
      if (gaps[i] < 0) gaps[i] = 0;
    }
  }
  let newAngles = [originalAngles[0]];
  for (let i = 0; i < n - 1; i++) {
    let nextAngle = newAngles[i] + gaps[i];
    if (nextAngle >= 360) nextAngle -= 360;
    newAngles.push(nextAngle);
  }
  newAngles.sort((a, b) => a - b);
  return newAngles;
}

function findClosestGapAngle(beadAngles, targetAngle) {
  if (beadAngles.length < 2) return targetAngle;
  const sorted = [...beadAngles].sort((a, b) => a - b);
  let bestMid = targetAngle;
  let bestDistance = Infinity;
  for (let i = 0; i < sorted.length; i++) {
    const start = sorted[i];
    const end = sorted[(i + 1) % sorted.length];
    let gapSize, mid;
    if (i === sorted.length - 1) {
      gapSize = (360 - start) + end;
      mid = (start + end + 360) / 2;
      if (mid >= 360) mid -= 360;
    } else {
      gapSize = end - start;
      mid = (start + end) / 2;
    }
    let dist = Math.abs(mid - targetAngle);
    dist = Math.min(dist, 360 - dist);
    if (dist < bestDistance) {
      bestDistance = dist;
      bestMid = mid;
    }
  }
  return bestMid;
}

function getQuadrant(angleDegrees) {
  angleDegrees = ((angleDegrees % 360) + 360) % 360;
  if (angleDegrees >= 315 || angleDegrees < 45) return 'right';
  if (angleDegrees >= 45 && angleDegrees < 135) return 'top';
  if (angleDegrees >= 135 && angleDegrees < 225) return 'left';
  return 'bottom';
}

function getQuadrantAdjustment(angleDegrees, sizeCode) {
  const quadrant = getQuadrant(angleDegrees);
  const sizeGap = sizeGaps[sizeCode] || 0;
  const quadrantGap = quadrantGaps[quadrant] || 0;
  return (sizeGap + quadrantGap) * Math.PI / 180;
}

function isAngleInFixedPart(angle, fixedParts) {
  angle = ((angle % 360) + 360) % 360;
  for (const part of fixedParts) {
    if (!part.enabled) continue;
    let start = (part.angle - part.width/2 + 360) % 360;
    let end = (part.angle + part.width/2) % 360;
    if (end < start) {
      if (angle >= start || angle <= end) return true;
    } else {
      if (angle >= start && angle <= end) return true;
    }
  }
  return false;
}

function getAvailableAngles(fixedParts, step = 1) {
  const availableAngles = [];
  for (let angle = 0; angle < 360; angle += step) {
    if (!isAngleInFixedPart(angle, fixedParts)) {
      availableAngles.push(angle);
    }
  }
  return availableAngles;
}

function getBeadPositions() {
  const parker = document.getElementById('parker');
  const droppers = Array.from(parker.querySelectorAll('.dropper'));
  const positions = [];
  droppers.forEach((dropper, index) => {
    if (dropper.style.display !== 'none') {
      const left = parseFloat(dropper.style.left);
      const top = parseFloat(dropper.style.top);
      positions.push({ left, top, index });
    }
  });
  return positions;
}

function calculateAngleBetweenBeads(bead1, bead2, centerX, centerY) {
  const angle1 = Math.atan2(bead1.top - centerY, bead1.left - centerX);
  const angle2 = Math.atan2(bead2.top - centerY, bead2.left - centerX);
  let avgAngle = (angle1 + angle2) / 2;
  if (Math.abs(angle1 - angle2) > Math.PI) avgAngle += Math.PI;
  return avgAngle;
}

function getBeadAngles() {
  const parker = document.getElementById('parker');
  const droppers = Array.from(parker.querySelectorAll('.dropper:not([style*="display: none"])'));
  const centerX = beadSettings.centerX;
  const centerY = beadSettings.centerY;
  const beadAngles = [];
  droppers.forEach(dropper => {
    const left = parseFloat(dropper.style.left);
    const top = parseFloat(dropper.style.top);
    if (!isNaN(left) && !isNaN(top)) {
      let angle = Math.atan2(top - centerY, left - centerX) * 180 / Math.PI;
      angle = ((angle + 360) % 360);
      beadAngles.push(angle);
    }
  });
  return beadAngles;
}

function placeBeadsSimpleCircular(parker, beadCount, sizeCode) {
  const allDroppers = Array.from(parker.querySelectorAll('.dropper'));
  const centerX = beadSettings.centerX;
  const centerY = beadSettings.centerY;
  const radius = beadSettings.radius;
  allDroppers.forEach((dropper, index) => {
    if (index < beadCount) {
      dropper.style.display = 'flex';
      const baseAngle = ((index / beadCount) * 2 * Math.PI) - (Math.PI / 2);
      const equalSpacingRad = (equalSpacing * Math.PI) / 180;
      let angle = baseAngle + (index * equalSpacingRad);
      const angleDegrees = angle * 180 / Math.PI;
      angle += getQuadrantAdjustment(angleDegrees, sizeCode);
      const x = centerX + radius * Math.cos(angle);
      const y = centerY + radius * Math.sin(angle);
      dropper.style.left = `${x}%`;
      dropper.style.top = `${y}%`;
      dropper.style.transform = 'translate(-50%, -50%)';
      dropper.style.width = beadSettings.size + 'px';
      dropper.style.height = beadSettings.size + 'px';
      dropper.dataset.beadIndex = index;
    } else {
      dropper.style.display = 'none';
      delete dropper.dataset.beadIndex;
    }
  });
}

function placeBeadsInAvailableAngles(parker, beadCount, sizeCode, availableAngles) {
  const allDroppers = Array.from(parker.querySelectorAll('.dropper'));
  const centerX = beadSettings.centerX;
  const centerY = beadSettings.centerY;
  const radius = beadSettings.radius;
  const totalAvailableAngles = availableAngles.length;
  const angleStep = totalAvailableAngles / beadCount;
  for (let i = 0; i < beadCount; i++) {
    const dropper = allDroppers[i];
    if (!dropper) break;
    dropper.style.display = 'flex';
    const angleIndex = Math.floor(i * angleStep) % totalAvailableAngles;
    let angleDegrees = availableAngles[angleIndex];
    angleDegrees += (i * equalSpacing);
    let angle = angleDegrees * Math.PI / 180;
    angle += getQuadrantAdjustment(angleDegrees, sizeCode);
    const x = centerX + radius * Math.cos(angle);
    const y = centerY + radius * Math.sin(angle);
    dropper.style.left = `${x}%`;
    dropper.style.top = `${y}%`;
    dropper.style.transform = 'translate(-50%, -50%)';
    dropper.style.width = beadSettings.size + 'px';
    dropper.style.height = beadSettings.size + 'px';
    dropper.dataset.beadIndex = i;
  }
  for (let i = beadCount; i < allDroppers.length; i++) {
    allDroppers[i].style.display = 'none';
    delete allDroppers[i].dataset.beadIndex;
  }
}

function refreshCircularLayout() {
  if (window.pendingLayoutUpdate) cancelAnimationFrame(window.pendingLayoutUpdate);
  window.pendingLayoutUpdate = requestAnimationFrame(() => {
    const parker = document.getElementById('parker');
    if (!parker) return;
    const activeSizeCard = document.querySelector('.size-card.active');
    if (!activeSizeCard) return;
    const sizeCode = activeSizeCard.querySelector('h5').textContent.trim().toLowerCase();
    const beadCount = sizeBeadCounts[sizeCode] || 15;
    const availableAngles = getAvailableAngles(fixedParts);
    if (fixedParts.length === 0 || availableAngles.length === 0) {
      placeBeadsSimpleCircular(parker, beadCount, sizeCode);
    } else {
      placeBeadsInAvailableAngles(parker, beadCount, sizeCode, availableAngles);
    }
    applyExtraGaps();
    
    // Defer static elements to next frame to avoid long tasks
    requestAnimationFrame(() => {
        placeStaticImages();
        placeKnotBeads();
        positionLockEr();
    });
  });
}

function applyExtraGaps() {
  const parker = document.getElementById('parker');
  const droppers = Array.from(parker.querySelectorAll('.dropper:not([style*="display: none"])'));
  const beadCount = droppers.length;
  if (beadCount === 0) return;
  const centerX = beadSettings.centerX;
  const centerY = beadSettings.centerY;
  const radius = beadSettings.radius;
  let beadAngles = [];
  droppers.forEach(dropper => {
    const left = parseFloat(dropper.style.left);
    const top = parseFloat(dropper.style.top);
    let angle = Math.atan2(top - centerY, left - centerX) * 180 / Math.PI;
    angle = (angle + 360) % 360;
    beadAngles.push(angle);
  });
  beadAngles.sort((a, b) => a - b);
  const targetIndices = [];
  const extraSpacings = [];
  staticImages.forEach(image => {
    if (image.enabled && image.type === 'position-based' && image.extraSpacing > 0) {
      const pos = image.position - 1;
      if (pos < beadCount) {
        targetIndices.push(pos % beadCount);
        extraSpacings.push(image.extraSpacing);
      }
    }
  });
  if (targetIndices.length === 0) return;
  const newAngles = redistributeGaps(beadAngles, targetIndices, extraSpacings);
  const sortedIndices = newAngles.map((_, idx) => idx).sort((a, b) => newAngles[a] - newAngles[b]);
  for (let i = 0; i < beadCount; i++) {
    const dropper = droppers[sortedIndices[i]];
    const angleRad = newAngles[sortedIndices[i]] * Math.PI / 180;
    const x = centerX + radius * Math.cos(angleRad);
    const y = centerY + radius * Math.sin(angleRad);
    dropper.style.left = `${x}%`;
    dropper.style.top = `${y}%`;
  }
}

