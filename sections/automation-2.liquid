<script>

// ============================================
// GLOBAL VARIABLES & CONFIGURATION
// ============================================
const isDesignMode = window.Shopify && window.Shopify.designMode;

const sizeBeadCounts = {
  'xxs': {{ section.settings.bead_count_xxs | default: 12 }},
  'xs': {{ section.settings.bead_count_xs | default: 13 }},
