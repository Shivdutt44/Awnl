      extraSpacing: {{ section.settings.static_image_1_extra_spacing | default: 0 }},
      offset: {{ section.settings.static_image_1_offset | default: 0 }},
      rotation: {{ section.settings.static_image_1_rotation | default: 0 }},
      width: {{ section.settings.static_image_1_width | default: 40 }},
      height: {{ section.settings.static_image_1_height | default: 40 }},
      enabled: true,
      type: 'position-based'
    },
  {% endif %}
  {% if section.settings.static_image_2_enabled and section.settings.static_image_2 %}
    {
      src: "{{ section.settings.static_image_2 | image_url }}",
      position: {{ section.settings.static_image_2_position | default: 12 }},
      extraSpacing: {{ section.settings.static_image_2_extra_spacing | default: 0 }},
      offset: {{ section.settings.static_image_2_offset | default: 0 }},
      rotation: {{ section.settings.static_image_2_rotation | default: 0 }},
      width: {{ section.settings.static_image_2_width | default: 40 }},
      height: {{ section.settings.static_image_2_height | default: 40 }},
      enabled: true,
      type: 'position-based'
    },
  {% endif %}
  {% if section.settings.static_image_3_enabled and section.settings.static_image_3 %}
    {
      src: "{{ section.settings.static_image_3 | image_url }}",
      offset: {{ section.settings.static_image_3_offset | default: 0 }},
      rotation: {{ section.settings.static_image_3_rotation | default: 0 }},
      width: {{ section.settings.static_image_3_width | default: 50 }},
      height: {{ section.settings.static_image_3_height | default: 50 }},
      enabled: true,
      type: 'dynamic-top'
    },
  {% endif %}
  {% if section.settings.static_image_4_enabled and section.settings.static_image_4 %}
    {
      src: "{{ section.settings.static_image_4 | image_url }}",
