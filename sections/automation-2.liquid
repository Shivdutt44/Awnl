    const oldCard = document.querySelector(`.clasp-card[data-variant-id="${selectedClasp.variantId}"]`);
    if (oldCard) {
      const oldInventory = parseInt(oldCard.dataset.inventory, 10);
      const newQty = oldInventory + 1;
      oldCard.dataset.inventory = newQty;
      updateClaspStockUI(oldCard, newQty);
    }
    selectedClasp = null;
  }
  document.getElementById('clasp-image-container').innerHTML = '';
  // Remove clasp from any droppers (style-3)
  document.querySelectorAll('.dropper[data-has-clasp]').forEach(d => {
    d.querySelector('.selected-clasp')?.remove();
    d.removeAttribute('data-has-clasp');
  });
  // Remove clasp from knot beads (style-3)
  document.querySelectorAll('.knot-bead-dropper[data-has-clasp]').forEach(d => {
    d.innerHTML = '';
    d.removeAttribute('data-has-clasp');
    d.style.backgroundImage = d.dataset.placeholder || 'none';
    d.style.background = d.dataset.color || '';
    d.style.opacity = '0.3';
    d.style.zIndex = '9';
    d.style.outline = '';
    d.style.boxShadow = '';
  });
  updateTotalPrice();
  updateClaspCosting();
}

function initClaspSidebar() {
  const claspCards = document.querySelectorAll('.clasp-card');
  if (!claspCards.length) return;
  claspCards.forEach(card => {
    card.addEventListener('click', () => {
      if (card.classList.contains('is-disabled')) {
        alert("Insufficient stock for this clasp.");
        return;
      }
      claspCards.forEach(c => c.classList.remove('active'));
      card.classList.add('active');
      const variantId = card.dataset.variantId;
      const inventory = parseInt(card.dataset.inventory, 10);
      const price = parseFloat(card.dataset.price);
      const title = card.dataset.title;
      const image = card.dataset.image;
      if (selectedClasp) {
        const oldCard = document.querySelector(`.clasp-card[data-variant-id="${selectedClasp.variantId}"]`);
        if (oldCard) {
          const oldInventory = parseInt(oldCard.dataset.inventory, 10);
          const newQty = oldInventory + 1;
          oldCard.dataset.inventory = newQty;
          updateClaspStockUI(oldCard, newQty);
        }
      }
      selectedClasp = { variantId, title, price, image, inventory };
      const newInventory = inventory - 1;
      card.dataset.inventory = newInventory;
      updateClaspStockUI(card, newInventory);
      updateTotalPrice();
      updateClaspCosting();
      {% if product.handle contains 'style-3' or template.suffix == 'style-3' %}
      // Style-3: place clasp image in user-selected dropper/knot-bead positions
      const selectedDroppers   = document.querySelectorAll('.dropper.selected');
      const selectedKnotBeads  = document.querySelectorAll('.knot-bead-dropper.selected');
      // Remove existing clasp from any previous position
      document.querySelectorAll('.dropper[data-has-clasp]').forEach(d => {
        d.querySelector('.selected-clasp')?.remove();
        d.removeAttribute('data-has-clasp');
      });
      document.querySelectorAll('.knot-bead-dropper[data-has-clasp]').forEach(d => {
        d.innerHTML = '';
        d.removeAttribute('data-has-clasp');
        d.style.backgroundImage = d.dataset.placeholder || 'none';
        d.style.background = d.dataset.color || '';
        d.style.opacity = '0.3';
        d.style.zIndex = '9';
        d.style.outline = '';
        d.style.outlineOffset = '';
        d.style.boxShadow = '';
      });
      // Place clasp in regular selected droppers
      selectedDroppers.forEach(pos => {
        const existingStone = pos.querySelector('.selected-stone');
        if (existingStone) existingStone.remove();
        const claspDiv = document.createElement('div');
        claspDiv.classList.add('selected-stone', 'selected-clasp');
        const img = document.createElement('img');
        img.src = image;
        claspDiv.appendChild(img);
        pos.appendChild(claspDiv);
        pos.setAttribute('data-has-clasp', 'true');
        pos.classList.remove('selected');
      });
      // Place clasp in selected knot beads (cord tips)
      selectedKnotBeads.forEach(dot => {
        dot.innerHTML = '';
        const img = document.createElement('img');
        img.src = image;
        img.style.cssText = 'width:100%; height:100%; object-fit:cover; display:block; border-radius:50%;';
        dot.appendChild(img);
        dot.setAttribute('data-has-clasp', 'true');
        dot.classList.remove('selected');
        dot.style.backgroundImage = 'none';
        dot.style.background = 'transparent';
        dot.style.opacity = '1';
        dot.style.zIndex = '15';
        dot.style.outline = '';
        dot.style.outlineOffset = '';
        dot.style.boxShadow = 'none';
      });
      {% else %}
      placeClaspImage();
      {% endif %}
      const claspSidebar = document.getElementById('clasp-sidebar');
      if (claspSidebar) claspSidebar.classList.remove('active');
    });
  });
}

// ============================================
// EXISTING BEAD, STOCK, ENGRAVING, ETC. FUNCTIONS
// ============================================
function updateBeadStockUI(card, remaining) {
  const stockLabel = card.querySelector(".bead-stock");
  if (!stockLabel) return;
  if (remaining > 0) {
    stockLabel.textContent = `In stock: ${remaining}`;
    card.classList.remove("is-disabled");
    card.removeAttribute("aria-disabled");
  } else {
    stockLabel.textContent = "Insufficient stock";
    card.classList.add("is-disabled");
    card.setAttribute("aria-disabled", "true");
  }
}

function updateStoneCosting() {
  const stoneCostingContainer = document.querySelector(".stone-costing");
  stoneCostingContainer.innerHTML = "";
  let totalPrice = {{ product.price | divided_by: 100.0 }};
  for (let variantId in selectedStones) {
    const stone = selectedStones[variantId];
    const stoneGroup = document.createElement("div");
    stoneGroup.classList.add("stone-group");
    const titleDiv = document.createElement("div");
    titleDiv.classList.add("stone-title");
    titleDiv.textContent = `${stone.title} x ${stone.quantity}`;
    const priceDiv = document.createElement("div");
    priceDiv.classList.add("stone-price");
    const totalStonePrice = (stone.price * stone.quantity).toFixed(2);
    priceDiv.textContent = `NTD $${totalStonePrice}`;
    priceDiv.setAttribute("product-id", stone.stoneId);
    priceDiv.setAttribute("product-quantity", stone.quantity);
    priceDiv.setAttribute("product-title", stone.title);
    priceDiv.setAttribute("beads", "true");
    stoneGroup.appendChild(titleDiv);
    stoneGroup.appendChild(priceDiv);
    stoneCostingContainer.appendChild(stoneGroup);
    totalPrice += stone.price * stone.quantity;
  }
  document.querySelector(".price-count").textContent = `NTD $${totalPrice.toFixed(2)}`;
}

function resetProductForm() {
  const form = document.querySelector('form[action="/cart/add.js"]');
  if (form) form.reset();
  const stoneCosting = document.querySelector('.stone-costing');
  if (stoneCosting) stoneCosting.innerHTML = '';
  const priceCount = document.querySelector('.price-count');
  if (priceCount) priceCount.textContent = '{{ product.price | money_with_currency }}';
  const engravingText = document.getElementById('engraving-text');
  if (engravingText) { engravingText.value = ''; engravingText.style.border = ''; }
  const engravingOptions = document.querySelectorAll('.engraving-options input[type="radio"]');
  if (engravingOptions.length > 0) engravingOptions[0].checked = true;
  const giftWrapping = document.querySelector('input[name="properties[Gift Wrapping]"][value="free"]');
  if (giftWrapping) giftWrapping.checked = true;
  selectedStones = {};
  const droppers = document.querySelectorAll('.product-wrapper .product-beautify #parker .dropper');
  droppers.forEach(dropper => {
    dropper.classList.remove('selected');
    const selectedStone = dropper.querySelector('.selected-stone');
    if (selectedStone) selectedStone.remove();
  });
  syncKnotBeadColors();
  const beadWarning = document.getElementById('bead-warning');
  if (beadWarning) beadWarning.style.display = 'none';
  const addToCartBtn = document.querySelector('.add-cart');
  if (addToCartBtn) { addToCartBtn.disabled = false; addToCartBtn.style.opacity = '1'; }
  const errorMessage = document.querySelector('.error-message');
  if (errorMessage) errorMessage.style.display = 'none';
  resetClasp();
  document.querySelectorAll('.clasp-card').forEach(card => card.classList.remove('active'));
}

// ============================================
// CART SUBMISSION (MODIFIED)
// ============================================
document.addEventListener('DOMContentLoaded', function() {
  const form = document.querySelector('form[action="/cart/add.js"]');
  if (!form) return;
  const html2canvasPromise = loadHtml2Canvas();
  form.addEventListener('submit', async function(e) {
    e.preventDefault();
    showLoader();
    document.querySelector("div#instruction").style.display = "none";
    const submitBtn = form.querySelector('[type="submit"]');
    const originalBtnText = submitBtn.value;
    submitBtn.value = 'Processing...';
    submitBtn.disabled = true;
    try {
      const imageData = await captureCustomDesign();
      const { mainProductData, beadItems, claspItem } = prepareCartData(form, imageData);
      await processCartSubmission(mainProductData, beadItems, claspItem);
      hideLoader();
      window.location.href = '/cart';
    } catch (error) {
      hideLoader();
      console.error('Cart Submission Error:', error);
      alert(error.message || 'Could not complete your request. Please try again.');
    } finally {
      submitBtn.value = originalBtnText;
      submitBtn.disabled = false;
    }
  });
  async function captureCustomDesign() {
    try {
      await html2canvasPromise;
      const element = document.getElementById('parker');
      if (!element) return null;
      let canvas = await html2canvas(element, { scale: 0.8, quality: 0.6, logging: false, useCORS: true, backgroundColor: '#ffffff' });
      let imageUrl = canvas.toDataURL('image/jpeg', 0.6);
      if (imageUrl.length > 60000) {
        canvas = await html2canvas(element, { scale: 0.6, quality: 0.4, logging: false, useCORS: true });
        imageUrl = canvas.toDataURL('image/jpeg', 0.4);
      }
      return imageUrl.length < 60000 ? imageUrl : null;
    } catch (error) {
      console.error('Design Capture Failed:', error);
      return null;
    }
  }
  function prepareCartData(form, imageData) {
    const formData = new FormData(form);
    const bundleId = 'bundle_' + Date.now();
    const mainProductData = {
      id: formData.get('id'),
      quantity: formData.get('quantity') || 1,
      properties: {
        'Bundle Id': bundleId,
        'Bracelet Size': formData.get('properties[Bracelet Size]'),
        'String Color': formData.get('properties[String Color]'),
        'Lock Style': formData.get('properties[Lock Style]'),
        'Gender': formData.get('properties[Gender]'),
        'Base Price': formData.get('properties[Base Price]'),
        'Gift Wrapping': formData.get('properties[Gift Wrapping]'),
        'Engraving': formData.get('properties[Engraving]'),
        'Text': formData.get('properties[Text]'),
        'Bead Items': Array.from(document.querySelectorAll('.stone-price[beads="true"]'))
          .map(el => {
            const title = el.getAttribute('product-title') || el.textContent.trim();
            const qty = el.getAttribute('product-quantity') || 1;
            return title ? `${title} x ${qty}` : null;
          })
          .filter(item => item)
          .join(', ')
      }
    };
    if (imageData) mainProductData.properties['Final Image'] = imageData;
    const beadItems = [];
    document.querySelectorAll('.stone-price[beads="true"]').forEach(el => {
      const id = el.getAttribute('product-id');
      const quantity = el.getAttribute('product-quantity') || 1;
      if (id) beadItems.push({ id, quantity });
    });
    const claspItem = selectedClasp ? { id: selectedClasp.variantId, quantity: 1 } : null;
    return { mainProductData, beadItems, claspItem };
  }
  async function processCartSubmission(mainProduct, beadItems, claspItem) {
    const mainResponse = await fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(mainProduct)
    });
    const mainResult = await mainResponse.json();
    if (!mainResponse.ok) throw new Error(mainResult.description || mainResult.message || 'Could not add item to cart.');
    for (const [index, item] of beadItems.entries()) {
      try {
        await fetch('/cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(item)
        });
        if (index < beadItems.length - 1) await new Promise(resolve => setTimeout(resolve, 300));
      } catch (error) {
        console.error(`Bead ${index + 1} failed:`, error);
      }
    }
    if (claspItem) {
      try {
        await fetch('/cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(claspItem)
        });
      } catch (error) {
        console.error('Clasp addition failed:', error);
      }
    }
  }
  function loadHtml2Canvas() {
    if (typeof html2canvas === 'function') return Promise.resolve();
    return new Promise((resolve, reject) => {
      const script = document.createElement('script');
      script.src = 'https://html2canvas.hertzen.com/dist/html2canvas.min.js';
      script.onload = resolve;
      script.onerror = () => reject(new Error('html2canvas failed to load'));
      document.head.appendChild(script);
    });
  }
});

// ============================================
// OTHER EVENT LISTENERS & INITIALIZATION
// ============================================
document.addEventListener('DOMContentLoaded', function() {
  // Sidebar functionality
  const buttons = document.querySelectorAll('.assets-btn');
  const sidebars = document.querySelectorAll('.assets-sidebar');
  let activeSidebar = null;
  buttons.forEach(button => {
    button.addEventListener('click', (e) => {
      e.stopPropagation();
      const sidebarId = button.id + '-sidebar';
      const sidebar = document.getElementById(sidebarId);
      if (activeSidebar === sidebar) {
        sidebar.classList.remove('active');
        activeSidebar = null;
      } else {
        sidebars.forEach(sb => sb.classList.remove('active'));
        sidebar.classList.add('active');
        activeSidebar = sidebar;
      }
    });
  });
  document.querySelectorAll('.close-btn').forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const sidebar = btn.closest('.assets-sidebar');
      sidebar.classList.remove('active');
      activeSidebar = null;
    });
  });
  // Engraving options
  const engravingOptions = document.querySelectorAll('input[name="properties[Engraving]"]');
  const engravingTextField = document.getElementById('Engraving_text_field');
  if (engravingTextField) engravingTextField.style.display = 'none';
  engravingOptions.forEach(option => {
    option.addEventListener('change', function() {
      engravingTextField.style.display = document.querySelector('input[name="properties[Engraving]"]:checked') ? 'block' : 'none';
    });
  });
  // Quantity input validation
  const quantityInput = document.querySelector('.Bquantity');
  if (quantityInput) {
    quantityInput.addEventListener('input', function() {
      if (this.value < 1 || this.value === '') this.value = 1;
    });
  }
  // Accordion
  document.querySelectorAll('.accordion-header').forEach(header => {
    header.addEventListener('click', () => {
      const accordionItem = header.parentElement;
      document.querySelectorAll('.accordion-item').forEach(item => {
        if (item !== accordionItem) item.classList.remove('active');
      });
      accordionItem.classList.toggle('active');
    });
  });
  // Validate droppers before add to cart
  const parker = document.getElementById('parker');
  const addToCartBtn = document.querySelector('input.add-cart');
  function isVisible(el) { return !!(el.offsetParent !== null && getComputedStyle(el).display !== 'none'); }
  // Validate droppers - throttled with requestAnimationFrame
  let validationPending = false;
  function validateDroppers() {
    if (validationPending) return;
    validationPending = true;
    requestAnimationFrame(() => {
        const droppers = parker.querySelectorAll('.dropper');
        let allValid = true;
        droppers.forEach(drop => {
          if (isVisible(drop) && !drop.querySelector('.selected-stone')) allValid = false;
        });
        const warning = document.getElementById('bead-warning');
        if (warning) warning.style.display = allValid ? 'none' : 'block';
        if (addToCartBtn) { addToCartBtn.disabled = false; addToCartBtn.style.opacity = '1'; }
        validationPending = false;
    });
  }
  const observer = new MutationObserver(() => validateDroppers());
  if (parker) {
    observer.observe(parker, { attributes: true, subtree: true, childList: true, attributeFilter: ['class', 'style'] });
    parker.addEventListener('click', (e) => { 
        if (e.target.closest('.dropper')) validateDroppers(); 
    });
    validateDroppers();
  }
  // Instruction close
  const closeBtn = document.getElementById('close-instruction');
  const instructionBox = document.getElementById('instruction');
  if (closeBtn && instructionBox) closeBtn.addEventListener('click', () => instructionBox.style.display = 'none');
  // Engraving text validation
  const engravingInput = document.getElementById('engraving-text');
  const errorMessage = document.querySelector('.error-message');
  if (engravingInput && errorMessage) {
    engravingInput.addEventListener('input', () => {
      let text = engravingInput.value;
      const chineseCharCount = (text.match(/[\u4e00-\u9fff]/g) || []).length;
      const latinCharCount = (text.match(/[a-zA-Z]/g) || []).length;
      const spaceCount = (text.match(/ /g) || []).length;
      const isChinese = chineseCharCount > 0;
      const isLatin = latinCharCount > 0;
      if (isChinese && !isLatin) {
        if (chineseCharCount > 13 || spaceCount > 12) {
          engravingInput.value = text.substring(0, engravingInput.value.length - 1);
          errorMessage.textContent = '最多可輸入 13 個中文字和 12 個空格。';
          errorMessage.style.display = 'block';
          return;
        }
      } else {
        if (latinCharCount > 15 || spaceCount > 4) {
          engravingInput.value = text.substring(0, engravingInput.value.length - 1);
          errorMessage.textContent = '最多可輸入 15 個英文字母和 4 個空格。';
          errorMessage.style.display = 'block';
          return;
        }
      }
      if (text.trim().length === 0) {
        errorMessage.textContent = '請輸入刻印文字。';
        errorMessage.style.display = 'block';
      } else {
        errorMessage.style.display = 'none';
      }
    });
  }
  function updateHangingStrings(colorText) {
    const lowerColor = colorText.toLowerCase();
    let cordSrc = "";
    if (lowerColor.includes("blk") || lowerColor.includes("black")) {
      cordSrc = "{{ section.settings.static_image_left | image_url: width: 400 }}";
    } else if (lowerColor.includes("brown")) {
      cordSrc = "{{ section.settings.static_image_right | image_url: width: 400 }}";
    }
    if (cordSrc) {
      staticImages.forEach(img => {
        if (img.containerId === 'static-image-left' || img.containerId === 'static-image-right') {
          img.src = cordSrc;
        }
      });
    }
  }

  // String color selection
  const StringColorCards = document.querySelectorAll('.stringcolor-card');
  const productSummery = document.querySelector(".product-summery");
  StringColorCards.forEach(card => {
    card.addEventListener('click', () => {
      StringColorCards.forEach(c => c.classList.remove('active'));
      card.classList.add('active');
      document.querySelector("img#emBrace").src = card.dataset.src;
      const selectedStringColor = card.querySelector('h6').textContent.trim();
      const colorDisplay = productSummery.querySelector("p.string-color b");
      if (colorDisplay) colorDisplay.textContent = selectedStringColor;
      const colorInput = document.querySelector('input[name="properties[String Color]"]');
      if (colorInput) colorInput.value = selectedStringColor;

      updateHangingStrings(selectedStringColor);
      placeStaticImages();
      // placeKnotBeads() intentionally skipped — knot bead positions don't change
      // on string color change, and recreating them would wipe any placed clasp.
      positionLockEr();
    });
  });
  // Lock style selection
  const lockstyleCards = document.querySelectorAll('.lockstyle-card');
  lockstyleCards.forEach(card => {
    card.addEventListener('click', () => {
      lockstyleCards.forEach(c => c.classList.remove('active'));
      card.classList.add('active');
      const parker = document.querySelector('#parker');
      const lockEr = document.querySelector('img#lockEr');
      const useOddSrc = parker.classList.contains('size-xxs') || parker.classList.contains('size-s') || parker.classList.contains('size-l');
      lockEr.src = useOddSrc ? card.dataset.oddSrc : card.dataset.src;
      const lockStyle = card.querySelector('h6').textContent.trim();
      const lockDisplay = productSummery.querySelector("p.lock-style b");
      if (lockDisplay) lockDisplay.textContent = lockStyle;
      const lockInput = document.querySelector('input[name="properties[Lock Style]"]');
      if (lockInput) lockInput.value = lockStyle;
      updateLockImageBasedOnSize();
    });
  });
  // Size selection
  const sizeCards = document.querySelectorAll('.size-card');
  const parkerEl = document.getElementById('parker');
  function updateLockImageBasedOnSize() {
    const activeSizeCard = document.querySelector('.size-card.active');
    if (!activeSizeCard) return;
    const sizeText = activeSizeCard.querySelector('p')?.textContent || '';
    const sizeNumberMatch = sizeText.match(/\d+(\.\d+)?/);
    const sizeNumber = sizeNumberMatch ? parseFloat(sizeNumberMatch[0]) : null;
    const activeLock = document.querySelector('.lockstyle-card.active');
    const lockEr = document.querySelector('#lockEr');
    if (!activeLock || sizeNumber === null || !lockEr) return;
    let newSrc;
    if (sizeNumber < 21) {
      if (sizeNumber % 2 !== 0) newSrc = activeLock.dataset.oddSrc;
      else newSrc = activeLock.dataset.src;
    } else if (sizeNumber >= 21) newSrc = activeLock.dataset.src;
    else newSrc = activeLock.dataset.oddSrc;
    lockEr.src = newSrc;
  }
  sizeCards.forEach(card => {
    card.addEventListener('click', () => {
      resetProductForm();
      sizeCards.forEach(c => c.classList.remove('active'));
      card.classList.add('active');
      const selectedSizeClass = card.querySelector('h5').textContent.trim().toLowerCase();
      const selectedSizeName = card.querySelector('div').textContent.trim();
      const sizeDisplay = productSummery.querySelector("p.size b");
      if (sizeDisplay) sizeDisplay.textContent = selectedSizeName;
      const sizeInput = document.querySelector('input[name="properties[Bracelet Size]"]');
      if (sizeInput) sizeInput.value = selectedSizeName;
      const currentSizeClass = Array.from(parkerEl.classList).find(cls => cls.startsWith('size-'));
      if (currentSizeClass) parkerEl.classList.remove(currentSizeClass);
      parkerEl.classList.add(`size-${selectedSizeClass}`);
      updateLockImageBasedOnSize();
      refreshCircularLayout();
      // Re-place knot beads after the 400ms CSS transition finishes so the final
      // parker pixel size is used for the cord-tip % calculation
      setTimeout(() => { placeKnotBeads(); positionLockEr(); }, 450);
      const sizeSidebar = document.getElementById('bracelet-size-sidebar');
      if (sizeSidebar) sizeSidebar.classList.remove('active');
      if (typeof activeSidebar !== 'undefined' && activeSidebar === sizeSidebar) activeSidebar = null;
    });
  });
  // Auto-select default size
  setTimeout(() => {
    const defaultSizeCard = document.querySelector('.size-card.active');
    if (defaultSizeCard) {
      const selectedSizeClass = defaultSizeCard.querySelector('h5').textContent.trim().toLowerCase();
      const selectedSizeName = defaultSizeCard.querySelector('div').textContent.trim();
      const sizeDisplay = document.querySelector(".product-summery p.size b");
      if (sizeDisplay) sizeDisplay.textContent = selectedSizeName;
      const sizeInput = document.querySelector('input[name="properties[Bracelet Size]"]');
      if (sizeInput) sizeInput.value = selectedSizeName;
      const currentSizeClass = Array.from(parkerEl.classList).find(cls => cls.startsWith('size-'));
      if (currentSizeClass) parkerEl.classList.remove(currentSizeClass);
      parkerEl.classList.add(`size-${selectedSizeClass}`);
      updateLockImageBasedOnSize();
      refreshCircularLayout();
      setTimeout(() => { placeKnotBeads(); positionLockEr(); }, 450);
    } else {
      const sizeCards = document.querySelectorAll('.size-card');
      if (sizeCards.length > 0) {
        const mSizeCard = Array.from(sizeCards).find(card => card.querySelector('h5')?.textContent.trim() === 'M') || sizeCards[0];
        sizeCards.forEach(c => c.classList.remove('active'));
        mSizeCard.classList.add('active');
        const selectedSizeClass = mSizeCard.querySelector('h5').textContent.trim().toLowerCase();
        const selectedSizeName = mSizeCard.querySelector('div').textContent.trim();
        const sizeDisplay = document.querySelector(".product-summery p.size b");
        if (sizeDisplay) sizeDisplay.textContent = selectedSizeName;
        const sizeInput = document.querySelector('input[name="properties[Bracelet Size]"]');
        if (sizeInput) sizeInput.value = selectedSizeName;
        const currentSizeClass = Array.from(parkerEl.classList).find(cls => cls.startsWith('size-'));
        if (currentSizeClass) parkerEl.classList.remove(currentSizeClass);
        parkerEl.classList.add(`size-${selectedSizeClass}`);
        updateLockImageBasedOnSize();
        refreshCircularLayout();
        setTimeout(() => { placeKnotBeads(); positionLockEr(); }, 450);
      }
    }
  }, 100);
  // Stone cards click handling (beads)
  const stoneCards = document.querySelectorAll(".stone-card:not(.clasp-card)");
  stoneCards.forEach(card => {
    card.addEventListener("click", () => {
      if (card.classList.contains("is-disabled")) { alert("Insufficient stock for this bead."); return; }
      const variantId = card.dataset.variantId;
      const inventory = parseInt(card.dataset.inventory, 10);
      const currentQty = selectedStones[variantId]?.quantity || 0;
      const remaining = inventory - currentQty;
      if (remaining <= 0) { updateBeadStockUI(card, 0); alert("Insufficient stock for this bead."); return; }
      const selectedPositions = document.querySelectorAll(".product-wrapper .product-beautify #parker .dropper.selected");
      selectedPositions.forEach(pos => {
        const existingStone = pos.querySelector(".selected-stone");
        if (existingStone) {
          const oldVariantId = existingStone.dataset.variantId;
          if (selectedStones[oldVariantId]) {
            selectedStones[oldVariantId].quantity -= 1;
            if (selectedStones[oldVariantId].quantity <= 0) delete selectedStones[oldVariantId];
            const oldCard = document.querySelector(`.stone-card[data-variant-id="${oldVariantId}"]`);
            if (oldCard) {
              const oldInventory = parseInt(oldCard.dataset.inventory, 10);
              const usedQty = selectedStones[oldVariantId]?.quantity || 0;
              updateBeadStockUI(oldCard, oldInventory - usedQty);
            }
            updateStoneCosting();
          }
          existingStone.remove();
        }
        const imgSrc = card.querySelector("img").src;
        const stoneTitle = card.querySelector("h6").textContent.trim();
        const priceElement = card.querySelector("[data-bead-price]");
        const stonePrice = parseFloat(priceElement.dataset.beadPrice);
        const stoneId = card.querySelector("input[data-bride-id]").dataset.brideId;
        if (selectedStones[variantId]) selectedStones[variantId].quantity += 1;
        else selectedStones[variantId] = { title: stoneTitle, price: stonePrice, quantity: 1, image: imgSrc, stoneId: stoneId, inventory: inventory };
        const updatedRemaining = inventory - selectedStones[variantId].quantity;
        updateBeadStockUI(card, updatedRemaining);
        updateStoneCosting();
        const div = document.createElement("div");
        div.classList.add("selected-stone");
        div.dataset.variantId = variantId;
        const img = document.createElement("img");
        img.src = imgSrc;
        div.appendChild(img);
        pos.appendChild(div);
        pos.classList.remove("selected");
      });
      syncKnotBeadColors();
      validateDroppers();
    });
  });
  // Dropper click toggling
  const droppers = document.querySelectorAll('.product-wrapper .product-beautify #parker .dropper');
  droppers.forEach(dropper => dropper.addEventListener('click', () => dropper.classList.toggle('selected')));
  // Initialize clasp sidebar
  initClaspSidebar();
  // Resize handling for static images and clasp
  let resizeTimeout;
  window.addEventListener('resize', function() {
    clearTimeout(resizeTimeout);
    resizeTimeout = setTimeout(() => {
      if (document.getElementById('parker')) {
        placeStaticImages();
        placeClaspImage();
        placeKnotBeads();
        positionLockEr();
      }
    }, 250);
  });
  // Initial calls
  const initialStringCard = document.querySelector('.stringcolor-card.active');
  if (initialStringCard) {
    updateHangingStrings(initialStringCard.querySelector('h6').textContent.trim());
  }
  // Show loader/hide loader
  window.showLoader = function() { document.getElementById('loadingOverlay').style.display = 'flex'; };
  window.hideLoader = function() { document.getElementById('loadingOverlay').style.display = 'none'; };
});

</script>


