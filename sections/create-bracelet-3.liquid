  <!-- Java Scripts -->
 <script>

  // Updated JavaScript with separate fixed parts for even and odd sizes
const isDesignMode = window.Shopify && window.Shopify.designMode;

// ============================================
// CONFIGURATION FROM SCHEMA SETTINGS
// ============================================

// Bead counts per size (from schema)
const sizeBeadCounts = {
    'xxs': {{ section.settings.bead_count_xxs | default: 12 }},
    'xs': {{ section.settings.bead_count_xs | default: 13 }},
    's': {{ section.settings.bead_count_s | default: 14 }},
    'm': {{ section.settings.bead_count_m | default: 15 }},
    'l': {{ section.settings.bead_count_l | default: 16 }},
    'xl': {{ section.settings.bead_count_xl | default: 17 }},
    'xxl': {{ section.settings.bead_count_xxl | default: 18 }},
    'xxxl': {{ section.settings.bead_count_xxxl | default: 19 }},
    '4xl': {{ section.settings.bead_count_4xl | default: 20 }}
};

// Fixed Design Parts for EVEN bead counts (12, 14, 16, 18, 20)
const evenFixedParts = [
  {% if section.settings.even_fixed_part_1_enabled %}
    {
      angle: {{ section.settings.even_fixed_part_1_angle | default: 0 }},
      width: {{ section.settings.even_fixed_part_1_width | default: 30 }},
      enabled: true
    },
  {% endif %}
  {% if section.settings.even_fixed_part_2_enabled %}
    {
      angle: {{ section.settings.even_fixed_part_2_angle | default: 120 }},
      width: {{ section.settings.even_fixed_part_2_width | default: 30 }},
      enabled: true
    },
  {% endif %}
  {% if section.settings.even_fixed_part_3_enabled %}
    {
      angle: {{ section.settings.even_fixed_part_3_angle | default: 240 }},
      width: {{ section.settings.even_fixed_part_3_width | default: 30 }},
      enabled: true
    },
  {% endif %}
];

// Fixed Design Parts for ODD bead counts (13, 15, 17, 19)
const oddFixedParts = [
  {% if section.settings.odd_fixed_part_1_enabled %}
    {
      angle: {{ section.settings.odd_fixed_part_1_angle | default: 80 }},
      width: {{ section.settings.odd_fixed_part_1_width | default: 30 }},
      enabled: true
    },
  {% endif %}
  {% if section.settings.odd_fixed_part_2_enabled %}
    {
      angle: {{ section.settings.odd_fixed_part_2_angle | default: 200 }},
      width: {{ section.settings.odd_fixed_part_2_width | default: 30 }},
      enabled: true
    },
  {% endif %}
  {% if section.settings.odd_fixed_part_3_enabled %}
    {
      angle: {{ section.settings.odd_fixed_part_3_angle | default: 320 }},
      width: {{ section.settings.odd_fixed_part_3_width | default: 30 }},
      enabled: true
    },
  {% endif %}
];

// Global bead settings
const beadSettings = {
  size: {{ section.settings.bead_size | default: 45 }},
  radius: {{ section.settings.bead_radius | default: 41 }},
  centerX: {{ section.settings.center_x | default: 50 }},
  centerY: {{ section.settings.center_y | default: 50 }}
};

// Size-specific gap adjustments
const sizeGaps = {
  'xxs': {{ section.settings.gap_xxs | default: 0 }},
  'xs': {{ section.settings.gap_xs | default: 0 }},
  's': {{ section.settings.gap_s | default: 0 }},
  'm': {{ section.settings.gap_m | default: 0 }},
  'l': {{ section.settings.gap_l | default: 0 }},
  'xl': {{ section.settings.gap_xl | default: 0 }},
  'xxl': {{ section.settings.gap_xxl | default: 0 }},
  'xxxl': {{ section.settings.gap_xxxl | default: 0 }},
  '4xl': {{ section.settings.gap_4xl | default: 0 }}
};

// Quadrant-specific gap adjustments
const quadrantGaps = {
  'top': {{ section.settings.gap_top | default: 0 }},
  'right': {{ section.settings.gap_right | default: 0 }},
  'bottom': {{ section.settings.gap_bottom | default: 0 }},
  'left': {{ section.settings.gap_left | default: 0 }}
};

// ============================================
// HELPER FUNCTIONS
// ============================================

function getQuadrant(angleDegrees) {
    // Normalize angle to 0-360
    angleDegrees = ((angleDegrees % 360) + 360) % 360;
    
    if (angleDegrees >= 315 || angleDegrees < 45) return 'right';
    if (angleDegrees >= 45 && angleDegrees < 135) return 'top';
    if (angleDegrees >= 135 && angleDegrees < 225) return 'left';
    return 'bottom';
}

function getQuadrantAdjustment(angleDegrees, sizeCode) {
    const quadrant = getQuadrant(angleDegrees);
    const sizeGap = sizeGaps[sizeCode] || 0;
    const quadrantGap = quadrantGaps[quadrant] || 0;
    
    // Convert total gap from degrees to radians
    return (sizeGap + quadrantGap) * Math.PI / 180;
}

function isEvenBeadCount(sizeCode) {
    const beadCount = sizeBeadCounts[sizeCode] || 15;
    return beadCount % 2 === 0;
}

function getFixedPartsForSize(sizeCode) {
    return isEvenBeadCount(sizeCode) ? evenFixedParts : oddFixedParts;
}

function isAngleInFixedPart(angle, fixedParts) {
    // Normalize angle to 0-360
    angle = ((angle % 360) + 360) % 360;
    
    for (const part of fixedParts) {
        if (!part.enabled) continue;
        
        // Calculate start and end angles based on center angle and width
        let start = (part.angle - part.width/2 + 360) % 360;
        let end = (part.angle + part.width/2) % 360;
        
        // Handle wrap-around (if end < start, it crosses 0°)
        if (end < start) {
            if (angle >= start || angle <= end) {
                return true;
            }
        } else {
            if (angle >= start && angle <= end) {
                return true;
            }
        }
    }
    return false;
}

function getAvailableAngles(fixedParts, step = 1) {
    const availableAngles = [];
    
    for (let angle = 0; angle < 360; angle += step) {
        if (!isAngleInFixedPart(angle, fixedParts)) {
            availableAngles.push(angle);
        }
    }
    
    return availableAngles;
}

// ============================================
// CORE BEAD POSITIONING LOGIC
// ============================================

function refreshCircularLayout() {
    const parker = document.getElementById('parker');
    if (!parker) return;

    // Get selected size from the active card
    const activeSizeCard = document.querySelector('.size-card.active');
    if (!activeSizeCard) return;
    
    const sizeCode = activeSizeCard.querySelector('h5').textContent.trim().toLowerCase();
    const beadCount = sizeBeadCounts[sizeCode] || 15;
    
    // Get fixed parts based on even/odd bead count
    const fixedParts = getFixedPartsForSize(sizeCode);

    // Get available angles for bead placement
    const availableAngles = getAvailableAngles(fixedParts);
    
    // If no fixed parts or no available angles, use simple circular layout
    if (fixedParts.length === 0 || availableAngles.length === 0) {
        placeBeadsSimpleCircular(parker, beadCount, sizeCode);
        return;
    }

    placeBeadsInAvailableAngles(parker, beadCount, sizeCode, availableAngles, fixedParts);
}

function placeBeadsSimpleCircular(parker, beadCount, sizeCode) {
    const allDroppers = Array.from(parker.querySelectorAll('.dropper'));
    const centerX = beadSettings.centerX;
    const centerY = beadSettings.centerY;
    const radius = beadSettings.radius;

    allDroppers.forEach((dropper, index) => {
        if (index < beadCount) {
            dropper.style.display = 'flex';
            
            // Calculate angle (starting from top)
            let angle = ((index / beadCount) * 2 * Math.PI) - (Math.PI / 2);
            
            // Apply quadrant adjustments
            const angleDegrees = angle * 180 / Math.PI;
            angle += getQuadrantAdjustment(angleDegrees, sizeCode);
            
            const x = centerX + radius * Math.cos(angle);
            const y = centerY + radius * Math.sin(angle);
            
            dropper.style.left = `${x}%`;
            dropper.style.top = `${y}%`;
            dropper.style.transform = 'translate(-50%, -50%)';
            
            // Apply bead size
            dropper.style.width = beadSettings.size + 'px';
            dropper.style.height = beadSettings.size + 'px';
        } else {
            dropper.style.display = 'none';
        }
    });
}

function placeBeadsInAvailableAngles(parker, beadCount, sizeCode, availableAngles, fixedParts) {
    const allDroppers = Array.from(parker.querySelectorAll('.dropper'));
    const centerX = beadSettings.centerX;
    const centerY = beadSettings.centerY;
    const radius = beadSettings.radius;
    
    // Calculate step between angles based on available angles
    const totalAvailableAngles = availableAngles.length;
    const angleStep = totalAvailableAngles / beadCount;
    
    for (let i = 0; i < beadCount; i++) {
        const dropper = allDroppers[i];
        if (!dropper) break;
        
        dropper.style.display = 'flex';
        
        // Get angle from available angles (distribute evenly)
        const angleIndex = Math.floor(i * angleStep) % totalAvailableAngles;
        let angleDegrees = availableAngles[angleIndex];
        
        // Convert to radians
        let angle = angleDegrees * Math.PI / 180;
        
        // Apply quadrant adjustments
        angle += getQuadrantAdjustment(angleDegrees, sizeCode);
        
        const x = centerX + radius * Math.cos(angle);
        const y = centerY + radius * Math.sin(angle);
        
        dropper.style.left = `${x}%`;
        dropper.style.top = `${y}%`;
        dropper.style.transform = 'translate(-50%, -50%)';
        
        // Apply bead size
        dropper.style.width = beadSettings.size + 'px';
        dropper.style.height = beadSettings.size + 'px';
    }
    
    // Hide any remaining droppers
    for (let i = beadCount; i < allDroppers.length; i++) {
        allDroppers[i].style.display = 'none';
    }
}



// ============================================
// QUANTITY INPUT VALIDATION
// ============================================

const quantityInput = document.querySelector('.Bquantity');
if (quantityInput) {
  quantityInput.addEventListener('input', function() {
    if (this.value < 1 || this.value === '') {
      this.value = 1;
    }
  });
}

// ============================================
// ENGRAVING OPTIONS HANDLING
// ============================================

document.addEventListener('DOMContentLoaded', function() {
  const engravingOptions = document.querySelectorAll('input[name="properties[Engraving]"]');
  const engravingTextField = document.getElementById('Engraving_text_field');

  // Start hidden
  if (engravingTextField) {
    engravingTextField.style.display = 'none';
  }

  engravingOptions.forEach(option => {
    option.addEventListener('change', function() {
      if (document.querySelector('input[name="properties[Engraving]"]:checked')) {
        engravingTextField.style.display = 'block'; 
      } else {
        engravingTextField.style.display = 'none'; 
      }
    });
  });
});

// ============================================
// SIDEBAR FUNCTIONALITY
// ============================================

const buttons = document.querySelectorAll('.assets-btn');
const sidebars = document.querySelectorAll('.assets-sidebar');
const productSummery = document.querySelector(".product-summery");
let activeSidebar = null;

buttons.forEach(button => {
  button.addEventListener('click', (e) => {
    e.stopPropagation();
    const sidebarId = button.id + '-sidebar';
    const sidebar = document.getElementById(sidebarId);

    if (activeSidebar === sidebar) {
      sidebar.classList.remove('active');
      activeSidebar = null;
    } else {
      sidebars.forEach(sb => sb.classList.remove('active'));
      sidebar.classList.add('active');
      activeSidebar = sidebar;
    }
  });
});

document.querySelectorAll('.close-btn').forEach(btn => {
  btn.addEventListener('click', (e) => {
    e.stopPropagation();
    const sidebar = btn.closest('.assets-sidebar');
    sidebar.classList.remove('active');
    activeSidebar = null;
  });
});

// ============================================
// FORM RESET FUNCTION
// ============================================

function resetProductForm() {
    // Reset form inputs to initial state
    const form = document.querySelector('form[action="/cart/add.js"]');
    if (form) form.reset();
    
    // Reset stone-costing section
    const stoneCosting = document.querySelector('.stone-costing');
    if (stoneCosting) stoneCosting.innerHTML = '';
    
    // Reset total fare to base price
    const priceCount = document.querySelector('.price-count');
    if (priceCount) priceCount.textContent = '{{ product.price | money_with_currency }}';
    
    // Reset engraving text input
    const engravingText = document.getElementById('engraving-text');
    if (engravingText) {
        engravingText.value = '';
        engravingText.style.border = '';
    }
    
    // Reset engraving options
    const engravingOptions = document.querySelectorAll('.engraving-options input[type="radio"]');
    if (engravingOptions.length > 0) {
        engravingOptions[0].checked = true;
    }
    
    // Reset gift wrapping to default
    const giftWrapping = document.querySelector('input[name="properties[Gift Wrapping]"][value="free"]');
    if (giftWrapping) giftWrapping.checked = true;
    
    // Clear selected stones object
    selectedStones = {};
    
    // Reset droppers
    const droppers = document.querySelectorAll('.product-wrapper .product-beautify #parker .dropper');
    droppers.forEach(dropper => {
        dropper.classList.remove('selected');
        const selectedStone = dropper.querySelector('.selected-stone');
        if (selectedStone) selectedStone.remove();
    });
    
    // Reset validation states
    const beadWarning = document.getElementById('bead-warning');
