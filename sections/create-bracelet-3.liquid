/* Selected dropper highlight ring - removed per user request */
.product-wrapper .product-beautify #parker .dropper.selected {
  opacity: 1 !important;
  outline: none;
}

/* Selected stone container — must NOT overflow to avoid bead overlap */
.product-wrapper .product-beautify #parker .dropper .selected-stone {
  width: 100%;
  height: 100%;
  overflow: hidden;
  border-radius: 50%;
}

/* Bead image — fills the dropper exactly, 3D look via shadows/filters only */
.product-wrapper .product-beautify #parker .dropper .selected-stone img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  border-radius: 50%;
  filter:
    drop-shadow(-2px -3px 4px rgba(255,255,255,0.25))
    drop-shadow(2px 4px 8px rgba(0,0,0,0.55))
    contrast(1.1)
    brightness(1.05);
  transition: filter 0.25s ease;
}

/* Subtle hover: deepen the shadow for a "pressed" effect */
.product-wrapper .product-beautify #parker .dropper:hover .selected-stone img {
  filter:
    drop-shadow(-2px -3px 4px rgba(255,255,255,0.3))
    drop-shadow(3px 6px 12px rgba(0,0,0,0.65))
    contrast(1.15)
    brightness(1.08);
}

.product-wrapper .product-beautify #parker .dropper:has(.selected-stone) {
  background-image: none !important;
  opacity: 1;
}

