/* ========================================= */
/* UPDATED: DYNAMIC BRACELET SIZING LOGIC   */
/* ========================================= */

/* 1. Define Bead Size (Fixed on Desktop, Responsive on Mobile) */
:root {
  /* Default for mobile/tablet */
  --bead-size: 11vw; 
}

/* Desktop: Beads stay fixed size (45px), Container grows */
@media (min-width: 768px) {
  :root {
    --bead-size: 45px;
  }

  /* Main Container: Remove strict max-width to allow growth */
  .product-wrapper .product-beautify #parker {
    max-width: 100% !important; 
    /* Smooth transition for resizing the bracelet circle */
    transition: width 0.4s cubic-bezier(0.25, 1, 0.5, 1), height 0.4s cubic-bezier(0.25, 1, 0.5, 1);
  }

  /* Bead (Dropper) Sizing - Use the variable, NOT percentage */
  .product-wrapper .product-beautify #parker .dropper {
    width: var(--bead-size) !important;
    height: var(--bead-size) !important;
  }

  /* 
     Size Map (Width/Height):
     Calculated to ensure beads don't overlap. 
     Formula: Circumference = (BeadCount * (BeadSize + Gap))
  */

  /* XXS: 16 Beads */
  .product-wrapper .product-beautify.style-1 #parker.size-xxs {
    width: 300px !important;
    height: 300px !important;
  }

  /* XS: 17 Beads */
  .product-wrapper .product-beautify.style-1 #parker.size-xs {
    width: 320px !important;
    height: 320px !important;
  }

  /* S: 18 Beads */
  .product-wrapper .product-beautify.style-1 #parker.size-s {
    width: 340px !important;
    height: 340px !important;
  }

  /* M: 20 Beads */
  .product-wrapper .product-beautify.style-1 #parker.size-m {
    width: 380px !important;
    height: 380px !important;
  }

  /* L: 21 Beads */
  .product-wrapper .product-beautify.style-1 #parker.size-l {
    width: 410px !important;
    height: 410px !important;
  }

  /* XL: 22 Beads */
  .product-wrapper .product-beautify.style-1 #parker.size-xl {
    width: 440px !important;
    height: 440px !important;
  }

  /* XXL: 23 Beads */
  .product-wrapper .product-beautify.style-1 #parker.size-xxl {
    width: 470px !important;
    height: 470px !important;
  }

  /* XXXL: 24 Beads */
  .product-wrapper .product-beautify.style-1 #parker.size-xxxl {
    width: 500px !important;
    height: 500px !important;
  }

  /* 4XL: 24 Beads */
  .product-wrapper .product-beautify.style-1 #parker.size-4xl {
    width: 510px !important;
    height: 510px !important;
  }
}

/* Mobile: Container fits screen, Beads use variable from root */
@media (max-width: 767px) {
  .product-wrapper .product-beautify #parker .dropper {
    width: var(--bead-size) !important;
    height: var(--bead-size) !important;
    background-size: var(--bead-size) var(--bead-size) !important;
  }
  
  /* Ensure container doesn't overflow on small screens, but allows sizing */
  .product-wrapper .product-beautify #parker {
    width: 90vw !important;
    height: 90vw !important;
    max-width: 90vw !important;
  }
}

/* ========================================= */
/* END UPDATED CSS                          */
/* ========================================= */

